// Conformance: ed25519 verify accepts a valid (pk, sig, msg) triple.
// Uses the public key + signature produced by the test vector in 019.

entry main(x: Text) {
    pk = "d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a"
    sig = "43b4331e5813891767d873247539ead11dd9475615e49af90aa7b2616f1c67b2318537870f425b581077fe781bf39595636076d6da2d481cbe1d5518c6bc4f0f"
    msg = "AIL conformance: ed25519"
    return to_text(crypto_verify_ed25519(pk, sig, msg))
}
