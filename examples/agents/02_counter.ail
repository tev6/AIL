// 02 — 카운터 / Counter
// 누른 횟수를 기억하는 에이전트. Run 누를 때마다 1씩 증가.
// 새로 배우는 것: `state.read` / `state.write` — 실행 사이에 숫자/텍스트
//                  를 기억. 채팅을 닫았다가 다시 켜도 값이 살아있어.

entry main(input: Text) {
    // 지금까지의 값을 읽어. 처음이면 "0"으로 시작.
    prev_r = perform state.read("count")
    prev = unwrap_or(prev_r, "0")

    // 1 더해서 다시 저장.
    next = to_text(to_number(prev) + 1)
    perform state.write("count", next)

    return ok(join(["지금까지 ", next, "번 눌렀어요."], ""))
}
