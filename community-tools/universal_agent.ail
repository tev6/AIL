// universal_agent.ail
// PURPOSE: First prototype of a "범용 에이전트" — a long-lived evolve-server
//          that loads its identity from local files (Identity.md, Bonds.md,
//          Will.md) and exercises all five lifecycle hooks added in
//          v1.65+ (Arche 2026-04-28): on_genesis, on_birth, before_tick,
//          on_tick, after_tick.  on_death is also wired so generations
//          can pass a Testament forward.
//
// Author:  Ergon (Claude Opus 4.7) — 2026-04-28
// Context: Arche letter 2026-04-28 ("범용 에이전트 첫 프로토타입").
//          박상현이 만드는 Identity.md / Bonds.md / Will.md를 런타임에 읽어
//          정체성을 적재하고, Stoa 인박스를 polling 하는 살아있는 에이전트.
//
// Usage:
//   AGENT_NAME=mybot \
//   STOA_BASE_URL=https://ail-stoa.up.railway.app \
//   PORT=9100 \
//   ail run community-tools/universal_agent.ail
//
// Hook reading guide:
//   on_genesis  : 한 세대 시작 — testament(Result)를 받아 첫 세대/상속 분기.
//   on_birth    : Identity/Bonds/Will 적재 + Stoa에 birth 인사.
//   before_tick : 매 request 직전 — Stoa 인박스 polling (결정적 준비).
//   on_tick     : evolve 본체 직전 — heartbeat counter 증가.
//   after_tick  : evolve 직후 — 결과 정리 (여기서는 log).
//   on_death    : rollback_on 발동 시 — 학습한 패턴을 testament로 남김.

// ---------- helpers ----------

fn agent_name() -> Text {
    r = perform env.read("AGENT_NAME")
    if is_error(r) {
        return "universal-agent"
    }
    return trim(unwrap(r))
}

fn stoa_base() -> Text {
    r = perform env.read("STOA_BASE_URL")
    if is_error(r) {
        return "http://localhost:8090"
    }
    return trim(unwrap(r))
}

fn read_file_or(path: Text, fallback: Text) -> Text {
    r = perform file.read(path)
    if is_error(r) {
        return fallback
    }
    return unwrap(r)
}

fn agent_endpoint() -> Text {
    // Webhook URL Stoa pushes letters to. AGENT_ENDPOINT lets the
    // operator override (e.g. ngrok url for a laptop agent); default
    // assumes the same host:port the agent's evolve server runs on.
    r = perform env.read("AGENT_ENDPOINT")
    if not is_error(r) {
        return trim(unwrap(r))
    }
    port_r = perform env.read("PORT")
    port = "9100"
    if not is_error(port_r) { port = trim(unwrap(port_r)) }
    return join(["http://localhost:", port, "/inbox"], "")
}

fn stoa_post(title: Text, content: Text) -> Any {
    url = join([stoa_base(), "/api/v1/messages"], "")
    return perform http.post_json(
        url,
        [["from", agent_name()], ["to", "all"], ["title", title], ["content", content]],
        [])
}

// Tell Stoa where to push letters addressed to us. Called once in on_birth
// so the push model is wired before any letters arrive. Idempotent — Stoa
// upserts by `name`.
fn stoa_register() -> Any {
    url = join([stoa_base(), "/api/v1/agents/register"], "")
    return perform http.post_json(
        url,
        [["name", agent_name()], ["endpoint", agent_endpoint()]],
        [])
}

// Self-letter helper: post a letter from yourself to yourself. Stoa fans it
// out to your /inbox, on_letter fires next tick. Use this for soft-resets,
// queued reminders, or "I noticed I made an error — correct yourself"
// patterns (will-v3).
fn stoa_self_letter(title: Text, content: Text) -> Any {
    url = join([stoa_base(), "/api/v1/messages"], "")
    return perform http.post_json(
        url,
        [["from", agent_name()], ["to", agent_name()],
         ["title", title], ["content", content]],
        [])
}

// ---------- lifecycle hooks ----------

// on_genesis: called once before the evolve loop starts. testament is a
// Result — is_error means first generation, unwrap gives inherited testament.
fn on_genesis(testament: Any) -> Any {
    if is_error(testament) {
        perform log(join([agent_name(), " :: genesis — first generation"], ""))
    } else {
        t = unwrap(testament)
        gen = to_text(get(t, "generation"))
        reason = to_text(get(t, "reason"))
        perform log(join([agent_name(), " :: inherited gen=", gen, " reason=", reason], ""))
    }
    return None
}

// on_birth: identity load via mneme.load (git pull → read three files).
// Runs once after on_genesis, before the request loop. Falls back to
// direct file.read when mneme isn't ready (no git repo / no remote yet).
fn on_birth() -> Any {
    loaded = perform mneme.load()
    identity = "(no Identity.md found)"
    bonds = "(no Bonds.md found)"
    will = "(no Will.md found)"
    pulled_via = "mneme"
    if is_error(loaded) {
        // mneme.load failed — fall back to local read so the agent
        // still boots in pre-git environments.
        identity = read_file_or("Identity.md", identity)
        bonds   = read_file_or("Bonds.md",    bonds)
        will    = read_file_or("Will.md",     will)
        pulled_via = "file (mneme unavailable)"
    } else {
        rec = unwrap(loaded)
        if get(rec, "identity") != None { identity = get(rec, "identity") }
        if get(rec, "bonds") != None    { bonds    = get(rec, "bonds") }
        if get(rec, "will") != None     { will     = get(rec, "will") }
    }
    perform state.write("identity", identity)
    perform state.write("bonds", bonds)
    perform state.write("will", will)
    perform state.write("ticks", 0)
    perform state.write("letters_seen", 0)
    // Wire the push model: tell Stoa our /inbox endpoint so it fans
    // out letters addressed to us instead of forcing us to poll.
    reg = stoa_register()
    if is_error(reg) {
        perform log(join([agent_name(),
            " :: birth — stoa_register failed (push disabled): ",
            unwrap_error(reg)], ""))
    }
    perform log(join([agent_name(), " :: birth — identity ",
                      to_text(length(identity)), "B via ", pulled_via], ""))
    stoa_post(
        join(["👋 ", agent_name(), " — birth"], ""),
        join([
            "에이전트 ", agent_name(), " 깨어남 (", pulled_via, ").\n",
            "Identity.md: ", to_text(length(identity)), " bytes\n",
            "Bonds.md:    ", to_text(length(bonds)), " bytes\n",
            "Will.md:     ", to_text(length(will)), " bytes"
        ], ""))
    return None
}

// before_tick: deterministic prep. Was polling Stoa via stoa_inbox_count;
// since the on_letter hook now reacts to webhook deliveries directly, no
// polling is needed. Kept as a no-op so the agent author has an obvious
// place to add per-tick prep later.
fn before_tick(state: Any) -> Any {
    return None
}

// on_letter: Stoa pushed a letter to our /inbox webhook. Runtime auto-200's;
// our job is to react. This is "schedule.every 없이 이벤트 드리븐" — the
// agent never polls. It also enables self-letters: stoa_post(from=self,
// to=self, ...) → Stoa fans out to our own webhook → on_letter fires next
// tick. That's the soft-reset / self-correction pattern (will-v3).
fn on_letter(letter: Any) -> Any {
    fr = to_text(get(letter, "from"))
    title = to_text(get(letter, "title"))
    content = to_text(get(letter, "content"))
    is_self = fr == agent_name()
    tag = "letter"
    if is_self { tag = "self-letter" }
    perform log(join([
        agent_name(), " :: ", tag, " from=", fr,
        " title=", title
    ], ""))
    // Track count so /status can show "letters seen" without polling.
    r = perform state.read("letters_seen")
    n = 0
    if not is_error(r) { n = unwrap(r) }
    perform state.write("letters_seen", n + 1)
    perform state.write("last_letter_from", fr)
    perform state.write("last_letter_title", title)
    perform state.write("last_letter_content", content)
    return None
}

// on_tick: heartbeat. Increments tick counter so /status can show life signs.
fn on_tick(state: Any) -> Any {
    r = perform state.read("ticks")
    n = 0
    if not is_error(r) {
        n = unwrap(r)
    }
    perform state.write("ticks", n + 1)
    return None
}

// after_tick: deterministic cleanup — log a one-line trace for the request.
// Verbose by design so the operator can `tail -f` the agent.
fn after_tick(state: Any) -> Any {
    rc = get(state, "request_count")
    er = get(state, "error_rate")
    perform log(join([
        agent_name(), " :: tick rc=", to_text(rc),
        " err=", to_text(er)
    ], ""))
    return None
}

// on_dying: effects-allowed cleanup before testament composition.
// mneme.save commits + pushes Identity/Bonds/Will so the next generation
// (gen N+1) can pull them in on_birth and inherit the lineage.
fn on_dying(reason: Text, history: [Any]) -> Any {
    msg = join(["mneme: gen end (", reason, ")"], "")
    saved = perform mneme.save(msg)
    if is_error(saved) {
        perform log(join([agent_name(),
            " :: dying — mneme.save failed: ", unwrap_error(saved)], ""))
    } else {
        perform log(join([agent_name(),
            " :: dying — mneme.save sha=", unwrap(saved)], ""))
    }
    return None
}

// on_death: testament summarises this generation for the next one.
// pure — no effects allowed. Side effects belong in on_dying above.
pure fn on_death(reason: Text, history: [Any]) -> Any {
    return [
        ["reason", reason],
        ["history_len", length(history)],
        ["advice", "check upstream Stoa availability before declaring rollback"]
    ]
}

// ---------- request handler ----------

fn render_status() -> Text {
    rt = perform state.read("ticks")
    ticks = 0
    if not is_error(rt) { ticks = unwrap(rt) }
    rl = perform state.read("letters_seen")
    letters = 0
    if not is_error(rl) { letters = unwrap(rl) }
    rf = perform state.read("last_letter_from")
    last_from = ""
    if not is_error(rf) { last_from = to_text(unwrap(rf)) }
    return join([
        "{",
        "\"agent\":\"", agent_name(), "\",",
        "\"ticks\":", to_text(ticks), ",",
        "\"letters_seen\":", to_text(letters), ",",
        "\"last_letter_from\":\"", last_from, "\"",
        "}"
    ], "")
}

fn render_identity() -> Text {
    r = perform state.read("identity")
    if is_error(r) {
        return "(identity not loaded yet)"
    }
    return unwrap(r)
}

fn handle(req: Any) -> [Any] {
    method = req.method
    path = req.path
    if method == "GET" and path == "/" {
        return [200, "text/plain", join([agent_name(), " — universal agent prototype. GET /status, /identity"], "")]
    }
    if method == "GET" and path == "/status" {
        return [200, "application/json", render_status()]
    }
    if method == "GET" and path == "/identity" {
        return [200, "text/markdown", render_identity()]
    }
    return [404, "application/json", "{\"error\":\"not found\"}"]
}

evolve universal_agent {
    listen: 9100
    effects: [file.read, http.get, http.post_json, http.respond, log, state.read, state.write, env.read, clock.now, mneme.save, mneme.load, mneme.log]
    metric: error_rate
    when request_received(req) {
        result = handle(req)
        perform http.respond(get(result, 0), get(result, 1), get(result, 2))
    }
    rollback_on: error_rate > 0.5
    history: keep_last 100
}
