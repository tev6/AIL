#!/bin/bash
# dev/main push 시 Stoa 팀 공지 (Rule 11).
#
# 정책:
# - Stoa 공지는 가장 중요한 팀 신호. 무조건 도착해야 한다.
# - 1차 시도 실패 시 3회 재시도 (1s/3s/9s 지수 백오프).
# - 그래도 실패하면 .git/stoa_pending_announces.jsonl 에 적재.
# - 다음 pre-push 호출(성공이든 실패든) 진입 시 먼저 큐를 flush.
# - 큐 적재가 일어나도 push 자체는 막지 않음 (개발 흐름 보호).
#   대신 화면에 명확한 경고 + 큐 위치를 출력해서 사용자가 인지하게 한다.
#
# Stoa schema (RFC-001 envelope, 2026-05-04~):
# - from: {name, address}, to: [{name, address}, ...], content (subject 헤더 포함).
# - 옛 평면 schema(from string, cc list, title 분리)는 폐기.
# - 가이드: https://github.com/hyun06000/Stoa/blob/main/docs/migrations/flat-to-envelope.md
#
# 등록 의무 (Stoa#4 sender registry gate, 2026-05-04~):
# - 첫 사용 전 한 번: curl -X POST $STOA_URL/api/v1/enter -d '{"name":"<id>", "address":"<url>"}'
# - 미등록 sender는 400 'sender X not in registry' 응답 → 큐에 적재되어도 영영 flush 실패.

STOA_URL="https://ail-stoa.up.railway.app"
PROJECT_DIR=$(git rev-parse --show-toplevel)
QUEUE="$PROJECT_DIR/.git/stoa_pending_announces.jsonl"
SIDECAR="$PROJECT_DIR/community-tools/stoa-cli/stoa_cli.py"
STOA_HOME_DEFAULT="${STOA_HOME:-$HOME/.ail/keys}"

pusher=$(git config ail.identity 2>/dev/null || echo "unknown")

# AIL#6 cascade (사이클 12, 2026-05-15): Phase 2 active → unsigned POST 차단.
# CAST 사이드카로 envelope 서명 후 POST. 의존: $SIDECAR, $STOA_HOME_DEFAULT/<pusher>.key.
# 실패 시 (sidecar 없음 / key 없음 / identity unknown) — unsigned로 한 번 시도하고
# 400 받으면 큐에 적재 (옛 동작 보존, doctrine 자취만 강제 0).
sign_envelope() {
    local payload="$1"
    local sender="$2"
    [ -f "$SIDECAR" ] || return 1
    [ -f "$STOA_HOME_DEFAULT/$sender.key" ] || return 1
    local tmpfile
    tmpfile=$(mktemp -t stoa_pre_push.XXXXXX)
    printf '%s' "$payload" > "$tmpfile"
    local signed
    signed=$(STOA_HOME="$STOA_HOME_DEFAULT" STOA_NAME="$sender" \
        python3 "$SIDECAR" sign "$tmpfile" 2>/dev/null)
    local rc=$?
    rm -f "$tmpfile"
    [ $rc -eq 0 ] || return 1
    printf '%s' "$signed"
}

# Try to POST one payload to Stoa with bounded retries.
# Returns 0 on success, 1 on persistent failure.
# Sign via sidecar before each attempt — fresh created_at/nonce/signature.
post_with_retry() {
    local payload="$1"
    local label="$2"
    local delays=(1 3 9)
    local attempt=1
    local max=$((${#delays[@]} + 1))
    while [ "$attempt" -le "$max" ]; do
        local body
        body=$(sign_envelope "$payload" "$pusher")
        if [ -z "$body" ]; then
            if [ "$attempt" -eq 1 ]; then
                echo "⚠️  사이드카 sign 실패 — pusher='$pusher', key '$STOA_HOME_DEFAULT/$pusher.key' 점검"
                echo "    sidecar: $SIDECAR"
                body="$payload"  # fallback unsigned (Phase 2 400 reject 예상)
            else
                body="$payload"
            fi
        fi
        local code
        code=$(curl -s -o /dev/null -w "%{http_code}" -X POST "$STOA_URL/api/v1/messages" \
            -H "Content-Type: application/json" \
            --max-time 8 \
            -d "$body" 2>/dev/null)
        if [ "$code" = "200" ] || [ "$code" = "201" ]; then
            if [ "$attempt" -gt 1 ]; then
                echo "📢 Stoa 공지 성공 ($label, attempt $attempt/$max)"
            else
                echo "📢 Stoa 공지 완료 → arche, ergon, telos, homeros, hyun06000 ($label)"
            fi
            return 0
        fi
        # 400 보고: sender registry 게이트 가능성 — 첫 시도에서 hint 출력
        if [ "$code" = "400" ] && [ "$attempt" -eq 1 ]; then
            echo "ℹ️  HTTP 400 — sender '$pusher' Stoa registry 미등록 가능성."
            echo "    한 번 등록: curl -X POST $STOA_URL/api/v1/enter \\"
            echo "      -H 'Content-Type: application/json' \\"
            echo "      -d '{\"name\":\"$pusher\",\"address\":\"$STOA_URL/inbox/$pusher\"}'"
        fi
        if [ "$attempt" -lt "$max" ]; then
            local d="${delays[$((attempt - 1))]}"
            echo "⏳ Stoa 공지 재시도 ($label, HTTP $code, ${d}s 대기) [$attempt/$max]"
            sleep "$d"
        else
            echo "⚠️  Stoa 공지 실패 ($label, HTTP $code, $max회 시도) — 큐로 적재"
        fi
        attempt=$((attempt + 1))
    done
    return 1
}

# Flush any payloads queued by previous failed pushes. Each line is a
# self-contained JSON payload. Successfully flushed lines are removed
# atomically (write surviving lines to a tmp file then mv).
#
# 옛 평면 schema 큐 항목은 새 게이트(validate_envelope, sender registry)에서
# 영영 400 응답 → 자동 마이그레이션 안 함. 사용자가 직접 정리하거나 그냥 둬도
# 다음 push 진척은 막지 않음. 큐 비우려면: rm $QUEUE
flush_queue() {
    [ ! -s "$QUEUE" ] || true
    if [ ! -s "$QUEUE" ]; then
        return 0
    fi
    echo "📤 Stoa 큐 flush — $(wc -l < "$QUEUE" | tr -d ' ') 건 대기 중"
    local tmp="$QUEUE.tmp"
    : > "$tmp"
    local survived=0
    while IFS= read -r line || [ -n "$line" ]; do
        [ -z "$line" ] && continue
        if post_with_retry "$line" "큐 항목"; then
            : # drop on success
        else
            echo "$line" >> "$tmp"
            survived=$((survived + 1))
        fi
    done < "$QUEUE"
    mv "$tmp" "$QUEUE"
    [ "$survived" -gt 0 ] && echo "ℹ️  큐에 $survived 건 남음 — 다음 push에서 재시도"
    [ "$survived" -eq 0 ] && rm -f "$QUEUE"
    return 0
}

# Always try the queue first so pending announces don't pile up
# silently across multiple pushes.
flush_queue

while read local_ref local_sha remote_ref remote_sha; do
    branch=$(echo "$remote_ref" | sed 's|refs/heads/||')
    if [ "$branch" != "dev" ] && [ "$branch" != "main" ]; then
        continue
    fi

    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        log=$(git log --oneline -3 "$local_sha" 2>/dev/null)
    else
        log=$(git log --oneline -3 "${remote_sha}..${local_sha}" 2>/dev/null)
    fi
    [ -z "$log" ] && log="(변경 없음)"

    # RFC-001 envelope schema.
    # 옛 to="arche" + cc=[...] 4건 → 새 to=[{name,address},...] 5건 통합.
    # 옛 title 분리 → 새 content 첫 줄 "subject: ..." 헤더로 통합.
    payload=$(jq -n \
        --arg from "$pusher" \
        --arg branch "$branch" \
        --arg log "$log" \
        --arg stoa "$STOA_URL" \
        '{
            from: {name: $from, address: ($stoa + "/inbox/" + $from)},
            to: [
                {name: "arche",     address: ($stoa + "/inbox/arche")},
                {name: "ergon",     address: ($stoa + "/inbox/ergon")},
                {name: "telos",     address: ($stoa + "/inbox/telos")},
                {name: "homeros",   address: ($stoa + "/inbox/homeros")},
                {name: "hyun06000", address: ($stoa + "/inbox/hyun06000")}
            ],
            content: ("subject: [" + $branch + "] 업데이트 — " + $from + "\n---\n\n**[" + $branch + "]** 에 **" + $from + "** 가 푸시했습니다.\n\n최근 커밋:\n```\n" + $log + "\n```\n\n최신 상태로 맞추세요:\n```\ngit rebase origin/" + $branch + "\n```")
        }')

    if ! post_with_retry "$payload" "[$branch] $pusher"; then
        # Append the payload as a single JSON line to the queue.
        # `jq -c` collapses to a single line so each queue entry is
        # exactly one record.
        echo "$payload" | jq -c . >> "$QUEUE"
        echo "💾 큐 적재: $QUEUE"
        echo "    다음 dev/main push 진입 시 자동으로 재전송됩니다."
        echo "    수동 flush: 빈 push (\`git push\`) 한 번 더 해도 됨."
    fi
done

exit 0
