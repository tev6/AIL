{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pytest *)",
      "Bash(ail *)",
      "Bash(cd reference-impl && python *)",
      "Bash(cd reference-impl && pytest *)"
    ],
    "deny": [
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(git clean -fd *)",
      "Bash(git clean -fdx *)",
      "Bash(git clean -dfx *)",
      "Bash(git clean -xdf *)",
      "Bash(git clean -x *)",
      "Bash(git branch -D *)",
      "Bash(git branch --delete --force *)",
      "Bash(git checkout --force *)",
      "Bash(git checkout -f *)",
      "Bash(git checkout -- *)",
      "Bash(git filter-branch *)",
      "Bash(git filter-repo *)",
      "Bash(git update-ref -d *)",
      "Bash(git rebase -i *)",
      "Bash(git reflog delete *)",
      "Bash(git reflog expire *)",
      "Bash(git gc --prune=now *)",
      "Bash(rm -r *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -R *)",
      "Bash(rm -f *)"
    ]
  }
}
